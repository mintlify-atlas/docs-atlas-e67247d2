  "keyFeatures": [
    "Custom Elements-based <trix-editor> web component",
    "Internal document model independent of contenteditable/execCommand",
    "Rich text formatting: bold, italic, strikethrough, links, headings, quotes, code blocks, lists",
    "Drag-and-drop and paste file attachment support",
    "Unlimited undo/redo history",
    "Form integration with Element Internals and constraint validation",
    "Programmatic editor API for document manipulation and selection control",
    "HTML sanitization via DOMPurify",
    "ESM and UMD distribution formats",
    "Rails Action Text integration"
  ],
  "publicApiSurface": [
